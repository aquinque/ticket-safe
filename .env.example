# ──────────────────────────────────────────────────────────────────────────────
# Ticket Safe — environment variables template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it is gitignored).
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (frontend — safe to expose in browser) ──────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-anon-key>

# ── Supabase Edge Function secrets (set via Supabase Dashboard → Secrets) ────
# Do NOT put these in .env for the frontend — they are server-side only.
#
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# SITE_URL=https://your-production-domain.com
# TICKET_SIGNING_SECRET=<openssl rand -base64 32>
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by Supabase.

# ── Anthropic API Key (for Claude integration) ──────────────────────────────
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here
