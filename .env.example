# ──────────────────────────────────────────────────────────────────────────────
# Ticket Safe — environment variables template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it is gitignored).
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (frontend — safe to expose in browser) ──────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<supabase-anon-key>

# Canonical site URL used for password-reset / signup redirect URLs.
# Set this in dev so links emailed from local builds land on production
# rather than http://localhost:5173. Leave blank in production.
VITE_SITE_URL=https://ticket-safe.eu

# ── Supabase Edge Function secrets (set via Supabase Dashboard → Secrets) ────
# Do NOT put these in .env for the frontend — they are server-side only.
#
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# SITE_URL=https://ticket-safe.eu
# TICKET_SIGNING_SECRET=<openssl rand -base64 32>
# RESEND_API_KEY=re_...                  # already used by notify-new-message
# SEND_EMAIL_HOOK_SECRET=v1,whsec_...    # from Auth → Hooks → Send Email
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by Supabase.

# ── Anthropic API Key (for Claude integration) ──────────────────────────────
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Sentry (frontend error monitoring) ───────────────────────────────────────
# DSN is safe to expose in the browser. Leave blank to disable Sentry.
VITE_SENTRY_DSN=

# Source-map upload (build-time only — set in CI, NOT in browser env).
# Create an internal-integration token at https://sentry.io with project:write
# and project:releases scopes. Without these, the @sentry/vite-plugin no-ops.
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=sntrys_...
